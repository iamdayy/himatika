# Application
APPNAME=Himatika
VERSION=1.0.0
PUBLIC_URI=http://localhost:3000
PUBLIC_URI_API=http://localhost:3000/api

# MongoDB
HIMATIKA_MONGODB_URI=mongodb://localhost:27017
DBNAME=himatika

# Auth / JWT
JWT_SECRET=your-jwt-secret-here
COOKIE_DOMAIN=localhost

# Encryption
# Generate once with: openssl rand -hex 32
# WARNING: Changing this key will make all previously encrypted data unreadable.
# WARNING: Never use the placeholder below in production. Replace it with a real generated key.
# Example format: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef (64 hex chars)
ENCRYPTION_KEY=


# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=

# reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Midtrans
MIDTRANS_URL=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=

# PDF Worker
PDF_WORKER_API_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upstash QStash
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=


# WAHA
WAHA_URL=
WAHA_SESSION=
